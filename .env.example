# Copy to .env and fill in. .env is gitignored.

# Hugging Face Hub write token (https://huggingface.co/settings/tokens)
# Used by `hf upload`, `scripts/deploy_to_space.py`, and the training scripts
# when they push the LoRA adapter to the Hub.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Weights & Biases API key
# (alternatively run `wandb login` once and let netrc handle it)
# WANDB_API_KEY=
